# Polymarket wallet (EOA private key, signature_type=0)
PK_HEX=0xYOUR_PRIVATE_KEY_HERE

# Polymarket proxy/funder address (optional). Only set if funds live in a Polymarket
# proxy wallet rather than the EOA. Leave unset for sig_type=0.
# FUNDER=0x0000000000000000000000000000000000000000

# Trading mode: when DRY_RUN=true the executor logs intended orders instead of
# signing. Default: true. Flip to false only after shadow_replay passes the gate.
DRY_RUN=true

# Bankroll in USDC. The bot treats this as hard capital; sizing and risk caps all
# derive from it. Start small.
BANKROLL_USD=50

# Risk rails (all dollar amounts in USDC)
DAILY_LOSS_LIMIT_USD=5
MAX_DRAWDOWN_PCT=0.15
MAX_POSITION_USD=10
MAX_OPEN_POSITIONS=5
MAX_PER_EVENT_USD=15
STOP_LOSS_PCT=0.15

# Path to vendored poly_data trades CSV used by the wallet ranker
POLY_DATA_TRADES_CSV=./vendor/poly_data/processed/trades.csv
